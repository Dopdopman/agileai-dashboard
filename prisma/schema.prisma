generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("Developer") // Admin, Manager, Developer
  tasks     Task[]   @relation("TaskAssignee")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  
  sprints     Sprint[]
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sprint {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  tasks     Task[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String    @id @default(uuid())
  title        String
  status       String    @default("To Do") // "To Do", "In Progress", "Done"
  storyPoints  Float     @default(0)
  
  // --- Timestamps for Agile Metrics ---
  createdAt    DateTime  @default(now()) // Start point for Lead Time
  startedAt    DateTime?                 // Start point for Cycle Time
  completedAt  DateTime?                 // End point for Lead/Cycle Time & Burndown
  updatedAt    DateTime  @updatedAt

  // --- Relations ---
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  sprintId     String?
  sprint       Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  
  assigneeId   String?
  assignee     User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  githubId    String?  @unique
}
